# OrzuAi web app (copy to .env.local)

NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google login (Supabase Auth → Providers → Google)
# Redirect URL: {NEXT_PUBLIC_APP_URL}/auth/callback

# Resend transactional email
# From format: DisplayName <local@your-domain.com>
RESEND_API_KEY=
RESEND_FROM_EMAIL=Support <support@orzuai.com>

OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
PEXELS_API_KEY=
JAMENDO_CLIENT_ID=

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/callback
CRON_SECRET=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=orzu-media
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=https://media.orzuai.com
R2_REGION=auto
