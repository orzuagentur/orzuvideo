# OrzuAi Admin — separate Vercel project (root: admin/)
# Never put these secrets on the public client app unnecessarily.
# ADMIN_PASSWORD / ADMIN_OWNER_USER_ID / ADMIN_SESSION_SECRET are obsolete — remove them.

NEXT_PUBLIC_APP_URL=http://localhost:3001

# Same Supabase project as the client site
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Media / storage
PEXELS_API_KEY=
JAMENDO_CLIENT_ID=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=orzu-media
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=
R2_REGION=auto
