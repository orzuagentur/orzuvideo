# OrzuAi Admin — separate Vercel project (root: admin/)
# Never share ADMIN_* secrets with the public client app.

NEXT_PUBLIC_APP_URL=http://localhost:3001

# Same Supabase project as client (service role ONLY here)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Owner profile id — music/media library scoped to this user
ADMIN_OWNER_USER_ID=

# Gate password (≥8 chars) + session HMAC secret (≥16 chars)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Media / storage (from web/.env.local)
PEXELS_API_KEY=
JAMENDO_CLIENT_ID=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=orzu-media
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=
R2_REGION=auto
